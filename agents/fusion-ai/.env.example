# ──────────────────────────────────────────────────────────────────────────────
# FusionAI — Multi-Model Configuration
# ──────────────────────────────────────────────────────────────────────────────

# ── FREE TIER APIs (start here) ────────────────────────────────────────────────

# Google Gemini — FREE tier: 15 req/min, ~1M tokens/day
# Get your free key → https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Optional: override model (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# Groq — FREE tier: fast Llama 3.3 70B inference
# Get your free key → https://console.groq.com
GROQ_API_KEY=
# Optional: override model (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# ── OPTIONAL PAID APIs ──────────────────────────────────────────────────────────

# Anthropic Claude — best for complex reasoning & writing
# Get key → https://console.anthropic.com
ANTHROPIC_API_KEY=
# Optional: override model (default: claude-sonnet-4-6)
# CLAUDE_MODEL=claude-sonnet-4-6

# OpenAI — strong code generation (Codex successor)
# Get key → https://platform.openai.com
OPENAI_API_KEY=
# Optional: override model (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# ── LOCAL FREE AI (Ollama) ────────────────────────────────────────────────────
# Install Ollama → https://ollama.ai
# Then run: ollama pull llama3.2   or   ollama pull codellama
# No API key needed — 100% local and free
OLLAMA_HOST=http://localhost:11434

# ── SERVER ────────────────────────────────────────────────────────────────────
PORT=8080
