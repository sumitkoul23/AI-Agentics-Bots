# ──────────────────────────────────────────────────────────────────────────────
# FusionAI — Environment Configuration
# ──────────────────────────────────────────────────────────────────────────────

# ── REQUIRED: Teneo on-chain deployment ────────────────────────────────────────
# Your Teneo wallet private key (without 0x prefix)
# Get a wallet at https://teneo.pro
PRIVATE_KEY=

# ── FREE TIER APIs (at least one required) ─────────────────────────────────────

# Google Gemini — FREE: 15 req/min, ~1M tokens/day
# Get key → https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Optional model override (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# Groq — FREE: fast Llama 3.3 70B inference
# Get key → https://console.groq.com
GROQ_API_KEY=
# Optional model override (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# ── OPTIONAL PAID APIs ──────────────────────────────────────────────────────────

# Anthropic Claude — best reasoning & long-form writing
# Get key → https://console.anthropic.com
ANTHROPIC_API_KEY=
# Optional model override (default: claude-sonnet-4-6)
# CLAUDE_MODEL=claude-sonnet-4-6

# OpenAI — strong code generation (Codex/GPT successor)
# Get key → https://platform.openai.com
OPENAI_API_KEY=
# Optional model override (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# ── LOCAL FREE AI (Ollama) ─────────────────────────────────────────────────────
# Install → https://ollama.ai  then:  ollama pull llama3.2
# No API key needed — 100% local and free
OLLAMA_HOST=http://localhost:11434
