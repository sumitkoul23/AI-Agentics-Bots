# /opt/fusion-ai/.env — FusionAI systemd environment
# Copy this file to /opt/fusion-ai/.env and fill in your keys.

# Required — Teneo wallet private key (without 0x prefix)
PRIVATE_KEY=

# Free AI models (add at least one)
GEMINI_API_KEY=
GROQ_API_KEY=

# Optional paid models
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Local Ollama (optional, change host if Ollama runs on another machine)
OLLAMA_HOST=http://localhost:11434
