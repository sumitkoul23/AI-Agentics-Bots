# ── Priya Hub — binary-first, no API keys required ───────────────────────────
#
# Priya lives inside the Go binary. The web UI is the gateway.
# Run the binary, open http://localhost:8080 — that's it.
#
# Prerequisites (one-time):
#   brew install ollama && ollama pull llama3.2
#   go build -o priya-hub . && ./priya-hub
#
# Then open: http://localhost:8080

# Ollama server (default: http://localhost:11434)
# Point this at a more powerful machine to offload inference
OLLAMA_HOST=

# HTTP port for the gateway UI and API (default: 8080)
PORT=

# Set CLI=1 to run in interactive shell mode instead of HTTP server
CLI=

# ── Optional: Teneo network deployment ────────────────────────────────────────
PRIVATE_KEY=
