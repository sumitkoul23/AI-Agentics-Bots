# ── Priya Hub — no API keys required ─────────────────────────────────────────
#
# The swarm runs 100% on-device using Ollama.
# Install: https://ollama.com
# Pull a model: ollama pull llama3.2

# Ollama server address (default: http://localhost:11434)
OLLAMA_HOST=

# HTTP port for the chat server (default: 8080)
PORT=

# Set CLI=1 to run in interactive terminal mode instead of HTTP server mode
CLI=

# ── Optional: Teneo deployment (not required for local use) ──────────────────
PRIVATE_KEY=
