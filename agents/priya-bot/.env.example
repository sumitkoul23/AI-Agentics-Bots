# ── Required ────────────────────────────────────────────────────────────────────

# Teneo wallet private key — needed to deploy the agent on the Teneo network
PRIVATE_KEY=

# Anthropic API key — gives Priya her intelligence (console.anthropic.com)
ANTHROPIC_API_KEY=

# ── Social Media OAuth Apps ──────────────────────────────────────────────────────
# Tokens are obtained automatically via /login <platform> — you only need the
# client ID (and secret where required) from each platform's developer portal.
#
# Twitter/X  →  https://developer.twitter.com/en/portal/dashboard
#   Create a "User Authentication" app, set callback: http://localhost:8080/callback/twitter
#   App type: "Web App" (confidential) or "Native App" (public client / PKCE only)
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=         # optional for public/PKCE-only apps
#
# LinkedIn   →  https://www.linkedin.com/developers/apps
#   Add "Sign In with LinkedIn" + "Share on LinkedIn" products
#   Callback URL: http://localhost:8080/callback/linkedin
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
#
# Instagram  →  https://developers.facebook.com/apps
#   Create a "Business" app, add Instagram Graph API + Facebook Login
#   Callback URL: http://localhost:8080/callback/instagram
#   Also set your Instagram Business Account ID below (found in Meta Business Suite)
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
#
# Reddit     →  https://www.reddit.com/prefs/apps
#   Type: "web app"  |  Callback: http://localhost:8080/callback/reddit
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
