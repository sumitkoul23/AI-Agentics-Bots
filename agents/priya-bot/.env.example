# ── Required ────────────────────────────────────────────────────────────────────
# Teneo wallet private key for agent deployment
PRIVATE_KEY=

# Claude API key — gives Priya her intelligence (get from console.anthropic.com)
ANTHROPIC_API_KEY=

# ── Trading & Finance (optional) ────────────────────────────────────────────────
# Enables live price data in trade plans
MARKET_DATA_KEY=

# Enables live order execution (advisory mode by default — use with caution)
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=

# ── Freelance & Jobs (optional) ─────────────────────────────────────────────────
# Unlocks live job search results from Upwork/Fiverr/LinkedIn APIs
JOBS_API_KEY=

# ── Social Media Posting (optional) ────────────────────────────────────────────
# Enables Priya to post directly to platforms (drafts only without these)
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

LINKEDIN_ACCESS_TOKEN=

INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

TIKTOK_ACCESS_TOKEN=

YOUTUBE_API_KEY=

# ── Email / Communication (optional) ───────────────────────────────────────────
# Enables Priya to send emails on your behalf
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
